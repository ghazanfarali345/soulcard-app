# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Atlas Configuration
# Get your connection string from: https://cloud.mongodb.com/v2/
# Format: mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/soul_card_db?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/soul_card_db?retryWrites=true&w=majority

# JWT Configuration (for future implementation)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRATION=24h

# Email Configuration (Gmail example - for future implementation)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password
MAIL_FROM=noreply@soulcard.com

# CORS Configuration
CORS_ORIGIN=*

# Application URLs
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=debug

